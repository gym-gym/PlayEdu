#################  PlayEdu ###################
# 前端 / API 对外端口
PLAYEDU_API_PORT=9700
PLAYEDU_PC_PORT=9800
PLAYEDU_H5_PORT=9801
PLAYEDU_ADMIN_PORT=9900

# JWT 签名密钥 (生产环境务必修改)
PLAYEDU_JWT_KEY=playeduxyz

# 是否限制同一账号同时登录 (true=同一账号只能在一处登录)
PLAYEDU_SA_TOKEN_IS_CONCURRENT=false

# 时区 (应用与 mysql 共用，默认上海时区)
PLAYEDU_TZ=Asia/Shanghai

# 演示模式开关 (true=资源删除时仅删 DB 记录，不真正删除 S3 文件，用于演示站)
# 生产环境请保持 false，否则会留下永久无法回收的 S3 孤儿对象
PLAYEDU_DEMO_MODE=false

# 数据库连接信息
# 容器内默认连 compose 内置的 mysql 服务；如需接外部 MySQL，改 PLAYEDU_DB_HOST/PORT
PLAYEDU_DB_HOST=mysql
PLAYEDU_DB_PORT=3306
# 数据库名 (应用端 DB_NAME 与 mysql 容器 MYSQL_DATABASE 初始化共用此值)
PLAYEDU_DB_NAME=playedu
PLAYEDU_DB_USER=root
# 数据库密码 (应用端 DB_PASS 与 mysql 容器 root 密码共用此值)
PLAYEDU_DB_PASS=playeduxyz

# 数据库连接池 (Hikari)
PLAYEDU_DB_POOL_MIN_IDLE=1
PLAYEDU_DB_POOL_MAX_SIZE=10
PLAYEDU_DB_POOL_CONN_TIMEOUT=30000      # 获取连接超时时间 (ms)
PLAYEDU_DB_POOL_IDLE_TIMEOUT=600000     # 空闲连接超时时间 (ms)
PLAYEDU_DB_POOL_MAX_LIFETIME=1800000    # 连接最大存活时间 (ms)

#################  MySQL ###################
# 宿主机映射端口 (容器内仍为 3306)
MYSQL_PORT=23307
